# Mesaar Logistics Operations API — example environment file.
#
# Copy this file to ".env" and adjust values for your environment. All values
# here are safe, non-secret placeholders intended for local development. NEVER
# commit a real .env with production secrets.
#
# Every variable corresponds to a field on app.core.config.Settings.

# --- Core / pre-existing settings -------------------------------------------
# SQLAlchemy database URL (psycopg2 driver).
DATABASE_URL=postgresql+psycopg2://mesaar:mesaar@localhost:5432/mesaar
# JWT signing secret. Generate a strong random value for non-local use.
SECRET_KEY=change-me-in-production-please-use-a-long-random-string
ACCESS_TOKEN_EXPIRE_MINUTES=30
TOKEN_ALGORITHM=HS256
BCRYPT_WORK_FACTOR=12

# --- Application metadata & runtime -----------------------------------------
ENVIRONMENT=development
APP_NAME=Mesaar Logistics Operations API
APP_VERSION=1.0.0
DEBUG=false
API_V1_PREFIX=/v1

# Comma-separated list of allowed CORS origins ("*" allows all).
CORS_ORIGINS=*

# --- Logging -----------------------------------------------------------------
LOG_LEVEL=INFO
LOG_JSON=true

# --- Request context headers -------------------------------------------------
REQUEST_ID_HEADER=X-Request-ID
TENANT_HEADER=X-Tenant-ID

# --- Redis (cache) -----------------------------------------------------------
REDIS_URL=redis://localhost:6379/0
CACHE_TTL_SECONDS=300

# --- Celery ------------------------------------------------------------------
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2
CELERY_TASK_MAX_RETRIES=3
CELERY_TASK_DEFAULT_RETRY_DELAY=5

# --- JWT / tokens ------------------------------------------------------------
REFRESH_TOKEN_EXPIRE_MINUTES=20160
JWT_ISSUER=mesaar
JWT_AUDIENCE=mesaar-clients

# --- Database connection pool ------------------------------------------------
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE_SECONDS=1800
DB_ECHO=false

# --- Metrics -----------------------------------------------------------------
PROMETHEUS_ENABLED=true
