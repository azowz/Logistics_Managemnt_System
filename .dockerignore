# Keep the build context small and avoid leaking local/secret artefacts.

# Version control & CI
.git
.gitignore
.github

# Local environment & secrets
.env
.env.*
!.env.example

# Python caches & build artefacts
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.eggs/
build/
dist/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/
.tox/

# Virtual environments
.venv/
venv/
env/

# Editor / OS noise
.idea/
.vscode/
*.swp
.DS_Store
Thumbs.db

# Container / orchestration definitions (not needed inside the image)
Dockerfile
docker-compose.yml
.dockerignore

# Docs, mobile, and frontend trees — irrelevant to the backend image
docs/
mobile/
ui/
design-system/

# Logs and local databases
*.log
*.sqlite3
