{
  "$meta": {
    "name": "Mesaar Design Tokens",
    "version": "1.0.0",
    "description": "Single source of truth for both the driver mobile app (mobile/src/theme) and the web consoles. Dark-first. Values extracted from the shipped mobile theme and extended with semantic + desktop tokens. Consumable via Style Dictionary -> CSS variables / TS.",
    "mode": "dark"
  },
  "color": {
    "core": {
      "background": "#090D14",
      "backgroundElevated": "#0C111A",
      "surface": "#121821",
      "surfaceElevated": "#161D29",
      "surfaceMuted": "#0F151E",
      "surfaceHover": "#1A2330",
      "border": "rgba(255,255,255,0.06)",
      "borderStrong": "rgba(255,255,255,0.12)",
      "overlay": "rgba(9,13,20,0.72)"
    },
    "brand": {
      "primary": "#2F6BFF",
      "primaryHover": "#3D78FF",
      "primaryPressed": "#2456D6",
      "primarySoft": "rgba(47,107,255,0.14)",
      "focusRing": "#5C8DFF"
    },
    "status": {
      "success": "#18C56E",
      "successSoft": "rgba(24,197,110,0.14)",
      "warning": "#FFB020",
      "warningSoft": "rgba(255,176,32,0.14)",
      "danger": "#FF5A5F",
      "dangerSoft": "rgba(255,90,95,0.12)",
      "info": "#3BA0FF",
      "infoSoft": "rgba(59,160,255,0.14)",
      "neutral": "#7D8BA3"
    },
    "text": {
      "primary": "#F4F7FB",
      "secondary": "#7D8BA3",
      "muted": "#5A6678",
      "onPrimary": "#FFFFFF",
      "link": "#5C8DFF"
    },
    "shipmentStatus": {
      "created": "#7D8BA3",
      "ready": "#3BA0FF",
      "assigned": "#9B7DFF",
      "in_transit": "#2F6BFF",
      "delivered": "#18C56E",
      "cancelled": "#5A6678",
      "returned": "#FFB020",
      "failed": "#FF5A5F"
    },
    "dataviz": {
      "series1": "#2F6BFF",
      "series2": "#18C56E",
      "series3": "#FFB020",
      "series4": "#9B7DFF",
      "series5": "#3BA0FF",
      "series6": "#FF5A5F",
      "gridline": "rgba(255,255,255,0.06)"
    },
    "map": {
      "base": "#0A0F18",
      "grid": "rgba(255,255,255,0.04)",
      "road": "rgba(125,139,163,0.18)",
      "route": "#2F6BFF",
      "routeGlow": "rgba(47,107,255,0.35)",
      "pickup": "#18C56E",
      "dropoff": "#FF5A5F"
    }
  },
  "space": {
    "0": 0, "xs": 4, "sm": 8, "md": 12, "lg": 16,
    "xl": 20, "xxl": 24, "xxxl": 32, "huge": 40, "section": 56
  },
  "radius": {
    "sm": 10, "md": 14, "lg": 18, "xl": 22, "xxl": 28, "pill": 999
  },
  "size": {
    "controlHeight": 44,
    "controlHeightSm": 36,
    "controlHeightLg": 56,
    "minTarget": 24,
    "rowHeightDense": 40,
    "rowHeightComfortable": 52,
    "sidebarWidth": 264,
    "sidebarCollapsed": 72
  },
  "font": {
    "family": {
      "arabic": "Tajawal, 'Noto Sans Arabic', system-ui, sans-serif",
      "latin": "Inter, system-ui, -apple-system, sans-serif",
      "mono": "'JetBrains Mono', ui-monospace, monospace"
    },
    "weight": { "regular": 400, "medium": 500, "bold": 700, "black": 800 },
    "scale": {
      "display": { "size": 30, "line": 40, "weight": 800 },
      "h1": { "size": 24, "line": 34, "weight": 700 },
      "h2": { "size": 20, "line": 30, "weight": 700 },
      "h3": { "size": 17, "line": 26, "weight": 700 },
      "bodyStrong": { "size": 15, "line": 24, "weight": 500 },
      "body": { "size": 15, "line": 24, "weight": 400 },
      "caption": { "size": 13, "line": 20, "weight": 400 },
      "micro": { "size": 11, "line": 16, "weight": 500 },
      "numeric": { "size": 22, "line": 28, "weight": 800 }
    }
  },
  "shadow": {
    "card": "0 10px 18px rgba(0,0,0,0.35)",
    "floating": "0 -6px 28px rgba(0,0,0,0.45)",
    "popover": "0 12px 32px rgba(0,0,0,0.5)"
  },
  "z": {
    "base": 0, "sticky": 100, "dropdown": 1000, "drawer": 1100,
    "modal": 1200, "toast": 1300, "tooltip": 1400
  },
  "breakpoint": {
    "sm": 640, "md": 768, "lg": 1024, "xl": 1280, "xxl": 1536
  },
  "motion": {
    "fast": 120, "base": 200, "slow": 320,
    "easing": "cubic-bezier(0.2, 0.8, 0.2, 1)"
  },
  "direction": {
    "default": "rtl",
    "note": "RTL-first. Use CSS logical properties (inline-start/end, margin-inline) so LTR locales mirror automatically."
  }
}
